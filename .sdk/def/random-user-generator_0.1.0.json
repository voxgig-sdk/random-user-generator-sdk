          "first": {
            "type": "string"
          },
          "last": {
            "type": "string"
          }
        }
      },
      "Location": {
        "type": "object",
        "properties": {
          "street": {
            "$ref": "#/components/schemas/Street"
          },
          "city": {
            "type": "string"
          },
          "state": {
            "type": "string"
          },
          "country": {
            "type": "string"
          },
          "postcode": {
            "oneOf": [
              {
                "type": "string"
              },
              {
                "type": "integer"
              }
            ]
          },
          "coordinates": {
            "$ref": "#/components/schemas/Coordinates"
          },
          "timezone": {
            "$ref": "#/components/schemas/Timezone"
          }
        }
      },
      "Street": {
        "type": "object",
        "properties": {
          "number": {
            "type": "integer"
          },
          "name": {
            "type": "string"
          }
        }
      },
      "Coordinates": {
        "type": "object",
        "properties": {
          "latitude": {
            "type": "string"
          },
          "longitude": {
            "type": "string"
          }
        }
      },
      "Timezone": {
        "type": "object",
        "properties": {
          "offset": {
            "type": "string"
          },
          "description": {
            "type": "string"
          }
        }
      },
      "Login": {
        "type": "object",
        "properties": {
          "uuid": {
            "type": "string",
            "format": "uuid"
          },
          "username": {
            "type": "string"
          },
          "password": {
            "type": "string"
          },
          "salt": {
            "type": "string"
          },
          "md5": {
            "type": "string"
          },
          "sha1": {
            "type": "string"
          },
          "sha256": {
            "type": "string"
          }
        }
      },
      "DateInfo": {
        "type": "object",
        "properties": {
          "date": {
            "type": "string",
            "format": "date-time"
          },
          "age": {
            "type": "integer"
          }
        }
      },
      "ID": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "value": {
            "type": "string",
            "nullable": true
          }
        }
      },
      "Picture": {
        "type": "object",
        "properties": {
          "large": {
            "type": "string",
            "format": "uri"
          },
          "medium": {
            "type": "string",
            "format": "uri"
          },
          "thumbnail": {
            "type": "string",
            "format": "uri"
          }
        }
      },
      "Info": {
        "type": "object",
        "properties": {
          "seed": {
            "type": "string"
          },
          "results": {
            "type": "integer"
